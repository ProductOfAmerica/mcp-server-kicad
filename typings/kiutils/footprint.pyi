@dataclass
class Attributes:
    type: str | None = ...
    boardOnly: bool = ...
    excludeFromPosFiles: bool = ...
    excludeFromBom: bool = ...
    allowMissingCourtyard: bool = ...
    @classmethod
    def from_sexpr(cls, exp: list) -> Attributes: ...
    def to_sexpr(self, indent: int = 0, newline: bool = False) -> str: ...

@dataclass
class Model:
    path: str = ...
    pos: Coordinate = ...
    scale: Coordinate = ...
    rotate: Coordinate = ...
    hide: bool = ...
    opacity: float | None = ...
    @classmethod
    def from_sexpr(cls, exp: list) -> Model: ...
    def to_sexpr(self, indent: int = 2, newline: bool = True) -> str: ...

@dataclass
class DrillDefinition:
    oval: bool = ...
    diameter: float = ...
    width: float | None = ...
    offset: Position | None = ...
    @classmethod
    def from_sexpr(cls, exp: list) -> DrillDefinition: ...
    def to_sexpr(self, indent: int = 0, newline: bool = False) -> str: ...

@dataclass
class PadOptions:
    clearance: str = ...
    anchor: str = ...
    @classmethod
    def from_sexpr(cls, exp: list) -> PadOptions: ...
    def to_sexpr(self, indent: int = 0, newline: bool = False) -> str: ...

@dataclass
class Pad:
    number: str = ...
    type: str = ...
    shape: str = ...
    position: Position = ...
    locked: bool = ...
    size: Position = ...
    drill: DrillDefinition | None = ...
    layers: list[str] = ...
    property: str | None = ...
    removeUnusedLayers: bool = ...
    keepEndLayers: bool = ...
    roundrectRatio: float | None = ...
    chamferRatio: float | None = ...
    chamfer: list[str] = ...
    net: Net | None = ...
    tstamp: str | None = ...
    pinFunction: str | None = ...
    pinType: str | None = ...
    dieLength: float | None = ...
    solderMaskMargin: float | None = ...
    solderPasteMargin: float | None = ...
    solderPasteMarginRatio: float | None = ...
    clearance: float | None = ...
    zoneConnect: int | None = ...
    thermalWidth: float | None = ...
    thermalGap: float | None = ...
    customPadOptions: PadOptions | None = ...
