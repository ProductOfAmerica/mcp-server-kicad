@dataclass
class Footprint:
    @property
    def libId(self) -> str: ...
    libraryNickname = ...
    entryName = ...
    @libId.setter
    def libId(self, symbol_id: str): ...
    version: str | None = ...
    generator: str | None = ...
    locked: bool = ...
    placed: bool = ...
    layer: str = ...
    tedit: str = ...
    tstamp: str | None = ...
    position: Position | None = ...
    description: str | None = ...
    tags: str | None = ...
    properties: dict = ...
    path: str | None = ...
    autoplaceCost90: int | None = ...
    autoplaceCost180: int | None = ...
    solderMaskMargin: float | None = ...
    solderPasteMargin: float | None = ...
    solderPasteRatio: float | None = ...
    clearance: float | None = ...
    zoneConnect: int | None = ...
    thermalWidth: float | None = ...
    thermalGap: float | None = ...
    attributes: Attributes = ...
    privateLayers: list[str] = ...
    netTiePadGroups: list[str] = ...
    graphicItems: list = ...
    pads: list[Pad] = ...
    zones: list[Zone] = ...
    groups: list[Group] = ...
    models: list[Model] = ...
    filePath: str | None = ...
    @classmethod
    def from_sexpr(cls, exp: list) -> Footprint: ...
    @classmethod
    def from_file(cls, filepath: str, encoding: str | None = None) -> Footprint: ...
    @classmethod
    def create_new(cls, library_id: str, value: str, type: str = 'other', reference: str = 'REF**') -> Footprint: ...
    def to_file(self, filepath=None, encoding: str | None = None): ...
    def to_sexpr(self, indent: int = 0, newline: bool = True, layerInFirstLine: bool = False) -> str: ...
