{
  "name": "kicad",
  "description": "KiCad EDA tools and design skills for Claude Code",
  "author": {
    "name": "ProductOfAmerica"
  },
  "repository": "https://github.com/ProductOfAmerica/mcp-server-kicad",
  "homepage": "https://github.com/ProductOfAmerica/mcp-server-kicad",
  "version": "0.5.3",
  "license": "MIT",
  "mcpServers": {
    "kicad": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp-server-kicad",
        "mcp-server-kicad"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-kicad-files.cjs\"",
            "timeout": 3000,
            "statusMessage": "Validating KiCad file access..."
          }
        ]
      }
    ]
  },
  "keywords": [
    "kicad",
    "eda",
    "schematic",
    "pcb",
    "electronics"
  ]
}
